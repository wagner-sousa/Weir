# Caminho para o arquivo .mcp.json no host.
# Quando definido, o Weir montara este arquivo como volume no container
# em vez de usar o ./.mcp.json padrao.
# Util para apontar para configuracoes MCP em outros projetos.
#
# Uso: docker compose up (usa ./.mcp.json como padrao)
#      MCP_CONFIG_SOURCE=~/outro-projeto/.mcp.json docker compose up
#
# MCP_CONFIG_SOURCE=

# Timeout em milissegundos para teste de conexao MCP (padrao: 5000)
MCP_CONNECTION_TIMEOUT=5000

# Timeout em milissegundos para adicao de MCP em CI (padrao: 30000, CI: 5000)
MCP_ADD_TIMEOUT=30000
