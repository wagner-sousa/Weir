# =============================================================================
# Weir — Configuration de ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste conforme necessario.
# Variaveis sem valor (= vazio) usam o padrao do codigo.
# =============================================================================

# ---------------------------------------------------------------------------
# Servidor HTTP (main API, porta 3000)
# ---------------------------------------------------------------------------

# Porta do servidor HTTP principal (padrao: 3000)
PORT=3000

# Host do servidor HTTP (padrao: 0.0.0.0)
HOST=0.0.0.0

# Ambiente de execucao: development | test | production (padrao: development)
NODE_ENV=development

# ---------------------------------------------------------------------------
# Arquivos de configuracao MCP
# ---------------------------------------------------------------------------

# Caminho para o arquivo .mcp.json dentro do container/processo
# (padrao: ./.mcp.json no diretorio de trabalho)
# MCP_CONFIG_PATH=./.mcp.json

# Caminho para o arquivo .mcp-auth.json (dados OAuth2)
# (padrao: mesmo diretorio do MCP_CONFIG_PATH, arquivo .mcp-auth.json)
# MCP_AUTH_CONFIG_PATH=

# ---------------------------------------------------------------------------
# Timeouts e conexao MCP
# ---------------------------------------------------------------------------

# Timeout em ms para testar conexao com backend MCP (padrao: 5000)
MCP_CONNECTION_TIMEOUT=5000

# TTL do cache de status em ms (padrao: 60000 — 1 minuto)
# MCP_CACHE_TTL=60000

# ---------------------------------------------------------------------------
# Servidor MCP dedicado (porta SSE)
# ---------------------------------------------------------------------------

# Porta do servidor MCP dedicado para conexoes SSE (/mcp/<name>)
# 0 = desabilitado (apenas main API) (padrao: 4000)
WEIR_MCP_PORT=4000

# ---------------------------------------------------------------------------
# Proxy MCP (modo --mcp) — reconexao
# ---------------------------------------------------------------------------

# Atraso base da reconexao exponencial em ms (padrao: 1000)
# WEIR_PROXY_RECONNECT_BASE_DELAY=1000

# Atraso maximo da reconexao em ms (padrao: 30000)
# WEIR_PROXY_RECONNECT_MAX_DELAY=30000

# Maximo de tentativas de reconexao (0 = infinito) (padrao: 10)
# WEIR_PROXY_RECONNECT_MAX_RETRIES=10

# Limite de mensagens enfileiradas durante desconexao (padrao: 100)
# WEIR_PROXY_BUFFER_LIMIT=100

# ---------------------------------------------------------------------------
# Proxy MCP (modo --mcp) — transportes
# ---------------------------------------------------------------------------

# Timeout em ms para conexao inicial com o backend (padrao: 5000)
# WEIR_PROXY_BACKEND_TIMEOUT=5000

# Intervalo do keepalive em ms (0 = desligado) (padrao: 15000)
# WEIR_PROXY_KEEPALIVE_MS=15000

# Timeout em ms para resposta via HTTP transport (padrao: 30000)
# WEIR_PROXY_HTTP_TIMEOUT=30000

# ---------------------------------------------------------------------------
# Docker Compose (usado apenas no docker-compose.yml)
# ---------------------------------------------------------------------------

# Caminho para o .mcp.json no HOST (montado como bind mount).
# Util para apontar para configuracoes MCP em outros projetos.
# Nao e lido pelo codigo — usado apenas pelo docker-compose.
# (padrao: ./.mcp.json)
# MCP_CONFIG_SOURCE=./.mcp.json

# ---------------------------------------------------------------------------
# Notas
# ---------------------------------------------------------------------------
# WEIR_PROXY_HTTP_TIMEOUT e usado pelo sendOneMessage() em proxy/index.ts.
# As demais WEIR_PROXY_* sao lidas de defaultProxyOptions() em proxy/types.ts
# e/ou diretamente em proxy/transport.ts.
